{
  "title": "LTX-2.3 FP8 Text-to-Video",
  "description": "Generate videos from text prompts using LTX-2.3 22B FP8 with 2x spatial upscaling. Outputs uploaded to Supabase Storage.",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "gpuCount": 1,
    "gpuIds": "ADA_48_PRO",
    "containerDiskInGb": 30,
    "allowedCudaVersions": ["12.8", "12.7"],
    "env": [
      {
        "key": "HF_TOKEN",
        "type": "string",
        "description": "HuggingFace token (Gemma 3 license required)"
      },
      {
        "key": "SUPABASE_URL",
        "type": "string",
        "description": "Supabase project URL"
      },
      {
        "key": "SUPABASE_SERVICE_KEY",
        "type": "string",
        "description": "Supabase service role key"
      },
      {
        "key": "SUPABASE_BUCKET",
        "type": "string",
        "default": "ltx-videos",
        "description": "Storage bucket name"
      },
      {
        "key": "SUPABASE_URL_EXPIRY_SECONDS",
        "type": "number",
        "default": "604800",
        "min": 3600,
        "max": 2592000,
        "description": "Signed URL expiry in seconds",
        "advanced": true
      }
    ]
  }
}
