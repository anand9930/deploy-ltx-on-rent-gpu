# HuggingFace (required for Docker build only — models are baked into the image)
# Gemma 3 requires accepting the license at https://huggingface.co/google/gemma-3-12b-it-qat-q4_0-unquantized
# At runtime, HF_TOKEN is optional (only needed if models are missing from the image)
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Supabase Storage (for video upload — optional, service works without it)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key   # NOT the anon key — server-side uploads need service role
SUPABASE_BUCKET=ltx-videos
SUPABASE_URL_EXPIRY_SECONDS=604800           # 7 days

# Model storage (override for custom mount paths)
MODEL_DIR=/models
